<?xml version="1.0" encoding="utf-8"?>
<!--
    layout_floating_panel.xml
    The expanded panel that appears when the user taps the bubble.
    Rendered as a WindowManager TYPE_APPLICATION_OVERLAY view.
    Width: 280dp — fits comfortable on all screens.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_panel">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Header row ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_github"
                app:tint="@color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="GitCommit Buddy"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <!-- Refresh button -->
            <ImageButton
                android:id="@+id/btnRefresh"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_refresh"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Refresh"
                app:tint="?attr/colorOnSurfaceVariant" />

            <!-- Close button -->
            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                app:tint="?attr/colorOnSurfaceVariant"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- ── Divider ─────────────────────────────────────────────────────── -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="?attr/colorOutline" />

        <!-- ── Progress bar (shown while refreshing) ───────────────────────── -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:indeterminate="true"
            android:visibility="gone"
            app:trackCornerRadius="4dp" />

        <!-- ── Commit status ───────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvCommitStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Loading…"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:gravity="center" />

        <!-- ── Last commit time ───────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvLastCommitTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text=""
            android:textSize="13sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center" />

        <!-- ── Repo name ──────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvLastCommitRepo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text=""
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="?attr/colorSecondary"
            android:gravity="center" />

        <!-- ── Streak ─────────────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvStreak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="🔥 0 day streak"
            android:textSize="14sp"
            android:textColor="?attr/colorPrimary"
            android:gravity="center" />

        <!-- ── Open GitHub button ─────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenGitHub"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="Open GitHub"
            android:textSize="14sp"
            app:icon="@drawable/ic_github"
            app:iconTint="@android:color/transparent"
            app:iconTintMode="src_atop"
            app:iconGravity="start" />

        <!-- ── Secondary action row ───────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <!-- Remind Me Later: reschedules a notification 1 hour from now -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRemindLater"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Later"
                android:textSize="12sp"
                app:icon="@drawable/ic_alarm"
                app:iconGravity="start"
                app:iconSize="14dp" />

            <!-- Mark as Done: dismisses reminder and shows success feedback -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMarkDone"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Done ✓"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
