<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Base theme (light) ─────────────────────────────────────────────── -->
    <style name="Theme.GitCommitBuddy" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand colour — GitHub green -->
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>

        <!-- Background & Surface -->
        <item name="android:colorBackground">#80A8F5C2</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>

        <!-- Error -->
        <item name="colorError">@color/md_theme_light_error</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>

        <!-- Window -->
        <item name="android:windowAnimationStyle">@style/WindowAnimationStyle</item>
    </style>

    <!-- ── Splash screen theme ────────────────────────────────────────────── -->
    <style name="Theme.GitCommitBuddy.Splash" parent="Theme.GitCommitBuddy">
        <item name="android:windowBackground">@color/github_green</item>
    </style>

    <!-- ── Toolbar ────────────────────────────────────────────────────────── -->
    <style name="Theme.GitCommitBuddy.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/github_green</item>
        <item name="titleTextColor">@color/white</item>
    </style>

    <!-- ── Activity transition animations ────────────────────────────────── -->
    <style name="WindowAnimationStyle">
        <item name="android:activityOpenEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@android:anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@android:anim/fade_out</item>
    </style>

</resources>
