<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glass background for the dot -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:startColor="#B3FFFFFF"
                android:centerColor="#80FFFFFF"
                android:endColor="#99FFFFFF"
                android:angle="135" />
            <stroke android:width="1dp" android:color="#4DFFFFFF" />
        </shape>
    </item>
    <!-- Inner subtle glow -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF" />
        </shape>
    </item>
</layer-list>
