<?xml version="1.0" encoding="utf-8"?>
<!--
    layout_floating_bubble.xml
    The draggable overlay bubble — always on top via WindowManager.
    Sized small (56dp) so it's unobtrusive.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="64dp"
    android:layout_height="64dp">

    <!-- Main bubble circle -->
    <FrameLayout
        android:id="@+id/bubbleBackground"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_bubble_main"
        android:elevation="12dp">

        <!-- GitHub logo icon -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_github"
            android:contentDescription="GitHub"
            app:tint="@color/white"
            android:alpha="0.9" />

        <!-- Status dot -->
        <ImageView
            android:id="@+id/ivStatus"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="2dp"
            android:src="@drawable/ic_warning"
            android:background="@drawable/bg_status_dot"
            android:padding="3dp"
            android:elevation="4dp" />
    </FrameLayout>
</FrameLayout>
