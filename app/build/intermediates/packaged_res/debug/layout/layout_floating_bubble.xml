<?xml version="1.0" encoding="utf-8"?>
<!--
    layout_floating_bubble.xml
    The draggable overlay bubble — always on top via WindowManager.
    Sized small (56dp) so it's unobtrusive.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="64dp"
    android:layout_height="64dp">

    <!-- Outer shadow ring -->
    <View
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/bg_bubble_shadow" />

    <!-- Main bubble circle -->
    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_bubble_main"
        android:elevation="8dp">

        <!-- GitHub logo icon -->
        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_github"
            android:contentDescription="GitHub"
            app:tint="@color/white" />

        <!-- Status dot (green = committed, red = not yet) -->
        <ImageView
            android:id="@+id/ivStatus"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="0dp"
            android:src="@drawable/ic_warning"
            android:background="@drawable/bg_status_dot"
            android:padding="2dp" />
    </FrameLayout>
</FrameLayout>
